# Bitcoin Prediction API - Environment Configuration Template
# Copy this file to .env and adjust values for your environment

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database Configuration
MONGODB_URL=mongodb://localhost:27017/bitcoin_predictions
MONGODB_DATABASE=bitcoin_predictions

# Cache Configuration (Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# External API Configuration
BINANCE_API_URL=https://data-api.binance.vision
COINGECKO_API_URL=https://api.coingecko.com/api/v3
API_TIMEOUT_SECONDS=5

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Mathematical Model Configuration
LOOKBACK_WINDOW=24
DEGREES_OF_FREEDOM=5.0
N_SIMULATIONS=10000
DEFAULT_CONFIDENCE_LEVEL=0.95

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json